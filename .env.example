# Copy to `.env.local`. No trailing slash on the API origin.

NEXT_PUBLIC_API_URL=http://localhost:5000

# Production (Vercel/Netlify/etc.): set this in the host’s Environment Variables, or use `.env.production` locally.
# NEXT_PUBLIC_API_URL=https://gdc-backend-yrit.onrender.com

# Optional: overrides X-Client-Version on API requests
# NEXT_PUBLIC_APP_VERSION=0.1.0
